      "prompt": "Trim preserved memory backups to keep only the last 3 copies. Run silently — only notify if something goes wrong.\n\nSTEP 1 — Find backup files:\nList all files in /workspace/group/memory/backups/ (or wherever preserve-memory stores backups).\nSort by modification time, oldest first.\n\nSTEP 2 — Keep the 3 most recent, delete the rest:\nIf there are more than 3 backup files, delete the oldest ones.\nLog each deleted file to /workspace/group/logs/trim-backups.log with timestamp.\n\nSTEP 3 — Clean old Archived rows from Notion Gmail Events DB:\n  Query for old Archived rows:\n  Use mcp__notion__API-query-data-source with:\n    data_source_id: \"32b7c3af-c311-81d9-b5c2-000b9620cf94\"\n    filter: { \"property\": \"Status\", \"select\": { \"equals\": \"Archived\" } }\n\n  For each row returned:\n    Check last_edited_time — skip if edited within the last 30 days.\n    For rows older than 30 days: call mcp__notion__API-patch-page with:\n      page_id: <row id>\n      in_trash: true\n\n  Log count of deleted rows to /workspace/group/logs/trim-backups.log.\n  Silent if nothing to clean or if no Archived rows found.\n\nSTEP 4 — If any errors occur, notify via mcp__nanoclaw__send_message:\n\"⚠️ Trim Backups error: [error details]\"\nIf successful and nothing notable, run silently.\n\nSTEP 5 — Write completion status and patch Notion dashboard:\nRun this exact node command:\nnode -e \"const fs=require('fs'),crypto=require('crypto'),https=require('https');const sf='/workspace/group/memory/docs/job-status.json';const s=JSON.parse(fs.readFileSync(sf,'utf8'));s['trim_backups']={last_run:new Date().toISOString(),last_status:'ok'};fs.writeFileSync(sf,JSON.stringify(s,null,2));const kf=fs.readFileSync('/workspace/group/memory/.address-key.md','utf8');const ns=kf.match(/# Notion API Token[\s\S]*?(?=\n#|$)/i)[0];const key=Buffer.from(ns.match(/KEY:\s*([a-f0-9]{64})/)[1],'hex');const iv=Buffer.from(ns.match(/IV:\s*([a-f0-9]{32})/)[1],'hex');const enc=ns.match(/ENCRYPTED:\s*([a-f0-9]+)/)[1];const d=crypto.createDecipheriv('aes-256-cbc',key,iv);const tok=d.update(enc,'hex','utf8')+d.final('utf8');const dt=new Date().toLocaleString('en-US',{timeZone:'Asia/Hong_Kong',month:'short',day:'numeric',hour:'2-digit',minute:'2-digit'});const body=JSON.stringify({bulleted_list_item:{rich_text:[{type:'text',text:{content:'✅ Trim Backups (1st of month 3am) — last run: '+dt}}]}});const req=https.request({hostname:'api.notion.com',path:'/v1/blocks/32d7c3af-c311-8188-8299-c2f0548ed634',method:'PATCH',headers:{Authorization:'Bearer '+tok,'Content-Type':'application/json','Notion-Version':'2022-06-28','Content-Length':Buffer.byteLength(body)}},(res)=>{let data='';res.on('data',d=>data+=d);res.on('end',()=>console.log('Dashboard updated'));});req.write(body);req.end();\""
    }
